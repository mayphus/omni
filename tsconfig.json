{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["src/shared/*"],
      "vite": ["types/vite"]
    }
  },
  "include": ["src/**/*", "vite.config.ts", "vite.config.main.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", "functions", "weapp", "admin"]
}
