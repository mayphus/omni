# Example environment file (do not commit real secrets)

# Build-time (exposed to client via Vite/weapp-vite; do NOT put secrets here)
VITE_APP_NAME=tongmeng-plant
VITE_ENV=development
# Example public API endpoint for admin web (optional)
# VITE_API_BASE=https://example.com/api

# WeChat Mini Program CI (local-only; used by miniprogram-ci scripts)
WECHAT_APP_ID=
# Path to local private key for miniprogram-ci (file lives outside git)
WECHAT_PRIVATE_KEY_PATH=./.private-wx.key

# CloudBase (TCB) CLI (local-only; or use `tcb login` interactively)
TCB_ENV_ID=
# Path to local private key for TCB CLI (file lives outside git)
TCB_PRIVATE_KEY=./.private-tcb.key

# Mini Program → CloudBase environment (public; used by wx.cloud.init)
# Set this in your .env.local to pin the target env
VITE_TCB_ENV_ID=

# Cloud function WeChat Pay configuration (runtime)
WECHAT_PAY_SUB_MCH_ID=
# Optional overrides (fall back to platform env + sensible defaults)
WECHAT_PAY_ENV_ID=
WECHAT_PAY_NOTIFY_FUNCTION=shop
WECHAT_PAY_BODY=Shop order payment
WECHAT_PAY_IP=127.0.0.1
