<view class="custom-tabbar">
  <van-tabbar
    active="{{active}}"
    bind:change="onChange"
    fixed
    placeholder
    safe-area-inset-bottom
  >
    <van-tabbar-item
      icon="home-o"
      link-type="switchTab"
      url="/pages/index/index"
    >Home</van-tabbar-item>
    <van-tabbar-item
      icon="user-o"
      link-type="switchTab"
      url="/pages/profile/index"
    >Profile</van-tabbar-item>
  </van-tabbar>
</view>
