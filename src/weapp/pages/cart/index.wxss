/* Reserve space for custom tab bar */
page {
  box-sizing: border-box;
  background: #f7f8fa;
}

.cart-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 24rpx 32rpx 0;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.04);
}

.cart-toolbar__checkbox {
  flex: none;
}

.cart-toolbar__summary {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  color: #666;
}

.cart-toolbar__total {
  margin-top: 4rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
}

.cart-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx 32rpx 0;
}

.cart-swipe {
  margin-bottom: 16rpx;
}

.cart-swipe:last-child {
  margin-bottom: 0;
}

.cart-swipe__actions {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  overflow: hidden;
}

.cart-swipe__delete {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.cart-swipe__delete::after {
  display: none;
}

.cart-swipe__delete-icon,
.cart-swipe__delete-text {
  color: #fff;
}

.cart-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid transparent;
}

.cart-item__checkbox {
  margin-top: 8rpx;
}

.cart-item__figure {
  width: 120rpx;
  height: 120rpx;
  flex: none;
  border-radius: 12rpx;
  overflow: hidden;
}

.cart-item__main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cart-item__title {
  font-size: 28rpx;
  line-height: 1.4;
  color: #111;
}

.cart-item__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.cart-item__price {
  color: #ff6b00;
  font-weight: 600;
  font-size: 30rpx;
}

.cart-item--active {
  border-color: #1989fa;
  box-shadow: 0 16rpx 50rpx rgba(25, 137, 250, 0.12);
}

.cart-secondary-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 32rpx 24rpx;
}

.cart-secondary-actions .van-button {
  flex: 1;
}
.cart-submit-bar-spacer {
  height: 220rpx;
}
.cart-submit-bar {
  bottom: 120rpx !important;
  z-index: 1200 !important;
}
