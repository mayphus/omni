page {
  background: #f7f8fa;
  min-height: 100vh;
}

.order-detail {
  padding: 24rpx 32rpx 120rpx;
  box-sizing: border-box;
}

.order-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.04);
}

.order-section__title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #111827;
}

.order-section--hero {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.order-hero__status {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.order-hero__copy {
  flex-shrink: 0;
}

.order-hero__id {
  font-size: 26rpx;
  color: #1f2933;
  font-weight: 500;
}

.order-hero__date {
  font-size: 24rpx;
  color: #6b7280;
}

.order-summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: #374151;
  padding: 8rpx 0;
}

.order-summary-row--total {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.order-item-price {
  font-size: 24rpx;
  color: #6b7280;
}

.order-address {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 26rpx;
  color: #374151;
}

.order-address__line--muted {
  color: #6b7280;
}

.van-tag + .van-button {
  margin-top: 16rpx;
}

.van-button + .van-tag {
  margin-top: 16rpx;
  align-self: flex-start;
}
