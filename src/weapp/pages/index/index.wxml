<!-- Top search -->
<van-search
  value="{{ searchValue }}"
  placeholder="{{ i18n.searchPlaceholder }}"
  shape="round"
  background="#ffffff"
  show-action
  bind:change="onSearchChange"
  bind:search="onSearchConfirm"
  bind:cancel="onSearchCancel"
/>

<!-- Announcement -->

<!-- Banner -->

<!-- Featured products -->
<block wx:if="{{ featuredLoading && !featuredLoaded }}">
  <van-skeleton title row="3" loading avatar />
</block>

<block wx:elif="{{ featuredProducts.length }}">
  <van-card
    wx:for="{{ featuredProducts }}"
    wx:key="id"
    price="{{ item.price }}"
    desc="{{ item.desc }}"
    title="{{ item.title }}"
    thumb="{{ item.imageUrl }}"
    currency="¥"
    data-product-id="{{ item.id }}"
    bind:tap="onOpenProduct"
  />
</block>

<block wx:elif="{{ featuredError }}">
  <van-empty image="error">
    <view slot="description">
      <view>{{ i18n.featuredErrorTitle }}</view>
      <view>{{ featuredError || i18n.featuredErrorDescription }}</view>
    </view>
    <van-button slot="bottom" type="primary" size="small" bind:click="onRetryFeatured">
      {{ i18n.featuredErrorAction }}
    </van-button>
  </van-empty>
</block>

<block wx:elif="{{ featuredLoaded }}">
  <van-empty image="search">
    <view slot="description">
      <view>{{ i18n.featuredEmptyTitle }}</view>
      <view>{{ i18n.featuredEmptyDescription }}</view>
    </view>
    <van-button slot="bottom" type="primary" plain size="small" disabled>{{ i18n.featuredEmptyAction }}</van-button>
  </van-empty>
</block>

<van-divider content-position="center">{{ i18n.endDivider }}</van-divider>
