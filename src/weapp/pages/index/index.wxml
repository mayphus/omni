<!-- Top search -->
<van-search placeholder="Search products" shape="round" disabled background="#ffffff" />

<!-- Banner -->
<van-image
  fit="cover"
  width="750rpx"
  height="320rpx"
  src="https://fastly.picsum.photos/id/4/5000/3333.jpg?hmac=ghf06FdmgiD0-G4c9DdNM8RnBIN7BO0-ZGEw47khHP4"
/>

<!-- Quick categories -->
<van-divider content-position="left">Quick Categories</van-divider>
<van-grid column-num="4" clickable border="{{ false }}">
  <van-grid-item icon="shop-o" text="Categories" />
  <van-grid-item icon="hot-o" text="Hot" />
  <van-grid-item icon="new-o" text="New" />
  <van-grid-item icon="coupon-o" text="Coupons" />
  <van-grid-item icon="like-o" text="Favorites" />
  <van-grid-item icon="cart-o" text="Cart" />
  <van-grid-item icon="gift-o" text="Gifts" />
  <van-grid-item icon="service-o" text="Support" />
</van-grid>

<!-- Featured products -->
<van-divider content-position="left">Featured</van-divider>
<van-cell-group inset>
  <van-cell title="Featured" label="Handpicked for you" border="false" />
</van-cell-group>

<van-card
  num="1"
  price="99.00"
  desc="High quality product"
  title="Sample Product A"
  thumb="https://img.yzcdn.cn/vant/ipad.jpeg"
  currency="¥"
>
  <view slot="tags"><van-tag type="danger" plain>NEW</van-tag></view>
</van-card>

<van-divider />

<van-card
  num="1"
  price="129.00"
  desc="Comfortable and durable"
  title="Sample Product B"
  thumb="https://img.yzcdn.cn/vant/ipad.jpeg"
  currency="¥"
>
  <view slot="tags"><van-tag type="primary" plain>HOT</van-tag></view>
</van-card>

<van-divider content-position="center">End</van-divider>
