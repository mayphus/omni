/* Reserve space for custom tab bar */
page {
  box-sizing: border-box;
  padding-bottom: calc(constant(safe-area-inset-bottom) + 50px);
  padding-bottom: calc(env(safe-area-inset-bottom) + 50px);
}

.home-banner {
  margin: 24rpx 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 60rpx rgba(25, 137, 250, 0.18);
}

.home-banner__slide {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.home-banner__image {
  width: 100%;
  height: 100%;
  display: block;
}

.home-banner__title {
  position: absolute;
  left: 24rpx;
  bottom: 24rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}
