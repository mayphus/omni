
.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f3ff 0%, #fff7ed 100%);
  padding: 32rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(31, 41, 55, 0.08);
}

.hero {
  margin-top: 32rpx;
  text-align: center;
}

.title {
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2937;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.actions { margin-top: 32rpx; }
.mt { margin-top: 16rpx; }

.footer {
  margin-top: 28rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 24rpx;
}
