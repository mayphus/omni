.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.top {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section {
  margin-top: 24rpx;
}

.banner {
  width: 100%;
  height: 320rpx;
  overflow: hidden;
  border-radius: 12rpx;
}

.section-header {
  margin: 32rpx 4rpx 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.section-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.product-list .van-card {
  margin: 16rpx 0;
}

.bottom-space { height: 48rpx; }
