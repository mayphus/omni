.product-detail {
  background-color: #f7f8fa;
  min-height: 100vh;
}

.product-detail__body {
  padding-bottom: calc(160rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.product-detail__gallery {
  background-color: #ffffff;
}

.product-detail__card {
  margin: 24rpx 24rpx 0;
}

.product-detail__card .van-card__title {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.6;
}

.product-detail__card .van-card__price,
.product-detail__card .van-card__price-integer {
  font-size: 44rpx;
  font-weight: 700;
}

.product-detail__card .van-card__price-currency {
  font-size: 32rpx;
  margin-right: 4rpx;
}

.product-detail__category {
  display: inline-block;
  margin-top: 16rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background-color: #f2f3f5;
  font-size: 24rpx;
  color: #596273;
}

.product-detail__section {
  margin: 24rpx;
  margin-bottom: 0;
  border-radius: 24rpx;
  overflow: hidden;
}

.product-detail__panel-padding {
  padding: 0;
}

.product-detail__description {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #323233;
  line-height: 1.6;
}

.product-detail__placeholder {
  padding: 16rpx 32rpx 32rpx;
  font-size: 26rpx;
  color: #969799;
}

.product-detail__popup {
  background: transparent !important;
}

.product-detail__popup-content {
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.product-detail__popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.product-detail__popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.product-detail__popup-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #ee0a24;
}

.product-detail__popup-section {
  margin-bottom: 24rpx;
}

.product-detail__popup-label {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.product-detail__sku-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.product-detail__sku-group .van-radio {
  margin: 0;
}

.product-detail__sku-group .van-radio__icon {
  display: none;
}

.product-detail__sku-group .van-radio__label {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  border: 1px solid #dfe4ea;
  background-color: #ffffff;
  font-size: 26rpx;
  color: #374151;
}

.product-detail__sku-group .van-radio--checked .van-radio__label {
  border-color: #1989fa;
  color: #1989fa;
  background-color: rgba(25, 137, 250, 0.08);
}

.product-detail__sku-group .van-radio--disabled .van-radio__label {
  color: #c8c9cc;
  border-color: #ebedf0;
}

.product-detail__popup-actions {
  display: flex;
  gap: 16rpx;
}

.product-detail__popup-actions .van-button {
  flex: 1;
}
