.product-detail {
  background-color: #f7f8fa;
  min-height: 100vh;
}

.product-detail__body {
  padding-bottom: calc(160rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.product-detail__gallery {
  background-color: #ffffff;
}

.product-detail__card {
  margin: 24rpx 24rpx 0;
}

.product-detail__card .van-card__title {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.6;
}

.product-detail__card .van-card__price,
.product-detail__card .van-card__price-integer {
  font-size: 44rpx;
  font-weight: 700;
}

.product-detail__card .van-card__price-currency {
  font-size: 32rpx;
  margin-right: 4rpx;
}

.product-detail__category {
  display: inline-block;
  margin-top: 16rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background-color: #f2f3f5;
  font-size: 24rpx;
  color: #596273;
}

.product-detail__section {
  margin: 24rpx;
  margin-bottom: 0;
  border-radius: 24rpx;
  overflow: hidden;
}

.product-detail__panel-padding {
  padding: 0;
}

.product-detail__description {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #323233;
  line-height: 1.6;
}

.product-detail__placeholder {
  padding: 16rpx 32rpx 32rpx;
  font-size: 26rpx;
  color: #969799;
}

.product-detail__popup {
  background-color: #ffffff;
}

.product-detail__popup-content {
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.product-detail__popup-header {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.product-detail__popup-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  background-color: #f3f4f6;
  object-fit: cover;
}

.product-detail__popup-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.product-detail__popup-subtitle {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: #9ca3af;
}

.product-detail__popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.product-detail__popup-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #ee0a24;
}

.product-detail__popup-selected {
  font-size: 26rpx;
  color: #374151;
}

.product-detail__popup-stock {
  font-size: 24rpx;
  color: #6b7280;
}

.product-detail__popup-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-detail__popup-label {
  font-size: 26rpx;
  color: #6b7280;
}

.product-detail__sku-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-detail__sku-radio {
  margin: 0;
}

.product-detail__sku-radio .van-radio__icon {
  display: none;
}

.product-detail__sku-radio .van-radio__label {
  display: block;
  padding: 24rpx;
  border-radius: 20rpx;
  border: 1px solid #e5e7eb;
  background-color: #ffffff;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.product-detail__sku-radio.van-radio--checked .van-radio__label {
  border-color: #2563eb;
  background-color: #eff6ff;
  box-shadow: 0 16rpx 36rpx -18rpx rgba(37, 99, 235, 0.45);
}

.product-detail__sku-option {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.product-detail__sku-option-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.product-detail__sku-option-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.product-detail__sku-option-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #2563eb;
}

.product-detail__sku-option-desc {
  font-size: 24rpx;
  color: #6b7280;
}

.product-detail__sku-option-check {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 32rpx;
  color: #2563eb;
}

.product-detail__sku-radio.van-radio--disabled .van-radio__label {
  background-color: #f9fafb;
  border-color: #e5e7eb;
}

.product-detail__sku-radio.van-radio--disabled .product-detail__sku-option-label,
.product-detail__sku-radio.van-radio--disabled .product-detail__sku-option-price,
.product-detail__sku-radio.van-radio--disabled .product-detail__sku-option-desc,
.product-detail__sku-radio.van-radio--disabled .product-detail__sku-option-check {
  color: #9ca3af;
}

.product-detail__popup-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-detail__popup-actions .van-button {
  flex: 1;
}
