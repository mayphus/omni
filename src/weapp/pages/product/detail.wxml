<view class="product-detail">
  <block wx:if="{{ loading }}">
    <van-skeleton avatar title row="5" loading />
  </block>

  <block wx:elif="{{ error }}">
    <van-empty image="error">
      <view slot="description">
        <view>{{ i18n.comingSoonTitle }}</view>
        <view>{{ error }}</view>
      </view>
      <van-button slot="bottom" type="primary" size="small" bind:tap="onReloadProduct">
        {{ i18n.retryButton }}
      </van-button>
    </van-empty>
  </block>

  <block wx:elif="{{ product }}">
    <view class="product-detail__body">
      <van-swipe class="product-detail__gallery" autoplay="3000" circular indicator-color="#ffffff" bind:change="onGalleryChange">
        <block wx:for="{{ gallery }}" wx:key="url">
          <van-swipe-item>
            <view data-url="{{ item }}" bindtap="onPreviewImage">
              <van-image fit="cover" width="750rpx" height="480rpx" src="{{ item }}" />
            </view>
          </van-swipe-item>
        </block>
      </van-swipe>

      <van-card
        class="product-detail__card"
        title="{{ product.title }}"
        desc="{{ product.subtitle || product.description || i18n.desc }}"
        price="{{ product.price.priceYuan }}"
        currency="¥"
        centered
        tag="{{ !purchasable ? i18n.stockSoldOut : lowStockLabel }}"
      >
        <view slot="bottom" wx:if="{{ product.category }}" class="product-detail__category">
          {{ product.category }}
        </view>
      </van-card>

      <van-panel class="product-detail__section product-detail__panel-padding" title="{{ i18n.detailsTab }}">
        <rich-text wx:if="{{ product.richDescription }}" nodes="{{ product.richDescription }}" />
        <view wx:elif="{{ product.description }}" class="product-detail__description">{{ product.description }}</view>
        <van-cell-group wx:if="{{ attributes.length }}" inset>
          <van-cell wx:for="{{ attributes }}" wx:key="key" title="{{ item.key }}" value="{{ item.value }}" />
        </van-cell-group>
        <block wx:if="{{ !product.description && !product.richDescription && !attributes.length }}">
          <view wx:for="{{ i18n.detailItems }}" wx:key="item" class="product-detail__placeholder">• {{ item }}</view>
        </block>
      </van-panel>

      <van-panel
        wx:if="{{ i18n.reviewItems && i18n.reviewItems.length }}"
        class="product-detail__section"
        title="{{ i18n.reviewsTab }}"
      >
        <van-cell-group inset>
          <van-cell
            wx:for="{{ i18n.reviewItems }}"
            wx:key="title"
            wx:for-index="index"
            title="{{ item.title }}"
            label="{{ item.label }}"
            border="{{ index !== i18n.reviewItems.length - 1 }}"
          />
        </van-cell-group>
      </van-panel>
    </view>

    <van-goods-action safe-area-inset-bottom>
      <block wx:for="{{ i18n.actionIcons }}" wx:key="icon">
        <van-goods-action-icon
          icon="{{ item.icon }}"
          text="{{ item.text }}"
          data-url="{{ item.url }}"
          data-link-type="{{ item.linkType }}"
          bind:tap="onActionIconTap"
        />
      </block>
      <van-goods-action-button
        wx:if="{{ i18n.actionButtons && i18n.actionButtons.length }}"
        type="{{ i18n.actionButtons[0].type }}"
        text="{{ i18n.actionButtons[0].text }}"
        disabled="{{ !purchasable }}"
        bind:tap="onAddToCart"
      />
      <van-goods-action-button
        wx:if="{{ i18n.actionButtons && i18n.actionButtons.length > 1 }}"
        type="{{ i18n.actionButtons[1].type }}"
        text="{{ i18n.actionButtons[1].text }}"
        disabled="{{ !purchasable }}"
        bind:tap="onBuyNow"
      />
    </van-goods-action>

    <van-popup
      class="product-detail__popup"
      show="{{ showPurchasePopup }}"
      round
      position="bottom"
      bind:close="onClosePurchasePopup"
    >
      <view class="product-detail__popup-content">
        <view class="product-detail__popup-header">
          <view class="product-detail__popup-title">{{ i18n.optionsTitle }}</view>
          <view class="product-detail__popup-price">¥{{ selectedSkuPriceText }}</view>
        </view>
        <view wx:if="{{ skuOptions.length }}" class="product-detail__popup-section">
          <view class="product-detail__popup-label">{{ i18n.skuLabel || 'Select option' }}</view>
          <van-radio-group class="product-detail__sku-group" value="{{ selectedSkuId }}" bind:change="onSkuChange">
            <van-radio
              wx:for="{{ skuOptions }}"
              wx:key="skuId"
              name="{{ item.skuId }}"
              disabled="{{ item.disabled }}"
            >
              {{ item.text }}
            </van-radio>
          </van-radio-group>
        </view>
        <view class="product-detail__popup-section">
          <view class="product-detail__popup-label">{{ i18n.quantity }}</view>
          <van-stepper
            value="{{ quantity }}"
            min="1"
            max="{{ selectedSkuStock > 0 ? selectedSkuStock : quantity }}"
            disabled="{{ !purchasable }}"
            bind:change="onQuantityChange"
            bind:overlimit="onQuantityOverLimit"
          />
        </view>
        <view class="product-detail__popup-actions">
          <van-button size="small" type="default" plain bind:tap="onClosePurchasePopup">
            {{ i18n.popupCancel || 'Cancel' }}
          </van-button>
          <van-button size="small" type="primary" bind:tap="onConfirmPurchase">
            {{ i18n.popupConfirm || 'Confirm' }}
          </van-button>
        </view>
      </view>
    </van-popup>
  </block>

  <block wx:else>
    <van-empty image="search">
      <view slot="description">
        <view>{{ i18n.comingSoonTitle }}</view>
        <view>{{ i18n.comingSoonDescription }}</view>
      </view>
    </van-empty>
  </block>
</view>
