<van-image
  fit="cover"
  width="750rpx"
  height="480rpx"
  src="https://img.yzcdn.cn/vant/ipad.jpeg"
/>

<van-divider content-position="left">Product</van-divider>
<van-cell-group inset>
  <van-cell title="Sample Product" label="Short description" border="false" />
  <van-cell title="Price" value="¥129.00" />
  <van-cell title="Rating" value="4.5" />
</van-cell-group>

<van-divider content-position="left">Options</van-divider>
<van-cell-group inset>
  <van-cell title="Options" border="false" />
  <van-cell title="Color" value="Red" is-link />
  <van-cell title="Size" value="M" is-link />
  <van-cell title="Quantity" border="false">
    <van-stepper slot="right-icon" value="1" disabled />
  </van-cell>
</van-cell-group>

<van-tabs sticky>
  <van-tab title="Details">
    <van-cell title="Detail A" />
    <van-cell title="Detail B" />
    <van-cell title="Detail C" />
  </van-tab>
  <van-tab title="Reviews">
    <van-cell title="Great product" label="by User A" />
    <van-cell title="Works well" label="by User B" />
  </van-tab>
</van-tabs>

<van-goods-action safe-area-inset-bottom>
  <van-goods-action-icon icon="chat-o" text="Service" />
  <van-goods-action-icon icon="cart-o" text="Cart" link-type="switchTab" url="/pages/cart/index" />
  <van-goods-action-button type="warning" text="Add to Cart" />
  <van-goods-action-button type="danger" text="Buy Now" />
</van-goods-action>
