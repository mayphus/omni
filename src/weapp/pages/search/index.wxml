<van-search
  value="{{ value }}"
  placeholder="{{ i18n.placeholder }}"
  shape="round"
  background="#ffffff"
  show-action
  bind:change="onChange"
  bind:search="onSearch"
  bind:cancel="onClear"
/>

<block wx:if="{{ loading }}">
  <van-loading size="24px" color="#1989fa" vertical>{{ i18n.loadingText }}</van-loading>
</block>

<block wx:elif="{{ error }}">
  <van-empty image="error" description="{{ error }}" />
</block>

<block wx:elif="{{ results.length }}">
  <van-divider content-position="center">{{ i18n.resultsTitle }}</van-divider>
  <van-card
    wx:for="{{ results }}"
    wx:key="id"
    price="{{ item.price }}"
    desc="{{ item.desc }}"
    title="{{ item.title }}"
    thumb="{{ item.imageUrl }}"
    currency="¥"
    data-product-id="{{ item.id }}"
    bind:tap="onSelect"
  />
</block>

<block wx:else>
  <van-empty image="search">
    <view slot="description">
      <view>{{ i18n.emptyTitle }}</view>
      <view>{{ i18n.emptyDescription }}</view>
    </view>
  </van-empty>
</block>
