{
  "name": "omni",
  "private": true,
  "version": "0.2.0",
  "description": "Children's Dream Planet: monorepo with weapp + functions + admin",
  "scripts": {
    "dev:admin": "shadow-cljs watch admin-app",
    "dev:weapp": "shadow-cljs watch weapp-app weapp-index weapp-category weapp-cart weapp-profile",
    "build:admin": "shadow-cljs release admin-app",
    "build:functions": "shadow-cljs release function-shop",
    "build:weapp": "shadow-cljs release weapp-app weapp-index weapp-category weapp-cart weapp-profile && npm run postbuild:weapp",
    "postbuild:weapp": "bb --classpath src/cljs scripts/postbuild.bb",
    "preview": "node preview.js",
    "build:all": "npm run build:weapp && npm run build:functions && npm run build:admin",
    "deploy:admin": "npm run build:admin && tcb hosting deploy admin -e cloud1-1g4nt4micf670d3d",
    "deploy:functions": "npm run build:functions && tcb fn deploy shop --force",
    "deploy:weapp": "npm run build:weapp && node scripts/weapp-deploy.js",
    "deploy:all": "node scripts/deploy-all.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "verify": "node scripts/verify.js"
  },
  "devDependencies": {
    "@cloudbase/cli": "^2.9.5",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.4.0",
    "esbuild": "^0.25.9",
    "husky": "^9.1.7",
    "miniprogram-api-typings": "^4.1.0",
    "miniprogram-automator": "^0.12.1",
    "miniprogram-ci": "^2.1.26",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadow-cljs": "^2.28.21",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.2",
    "vite": "^7.1.5",
    "vitest": "^2.1.9",
    "weapp-vite": "^5.1.7",
    "wx-server-sdk": "^3.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}
