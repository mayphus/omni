{
  "name": "tongmeng-plant",
  "private": true,
  "version": "0.2.0",
  "description": "Children's Dream Planet: monorepo with weapp + functions + admin",
  "scripts": {
    "dev:admin": "vite --config vite.config.main.ts --mode admin",
    "dev:weapp": "weapp-vite dev",
    "build:admin": "vite build --config vite.config.main.ts --mode admin",
    "build:functions": "vite build --config vite.config.main.ts --mode functions",
    "build:weapp": "weapp-vite build && node scripts/weapp-npm.js",
    "build:all": "node scripts/build-all.js",
    "deploy:admin": "pnpm run build:admin && tcb hosting deploy admin -e cloud1-1g4nt4micf670d3d",
    "deploy:functions": "pnpm run build:functions && tcb fn deploy shop --force",
    "deploy:weapp": "pnpm run build:weapp && node scripts/weapp-deploy.js",
    "deploy:all": "node scripts/deploy-all.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "verify": "node scripts/verify.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@cloudbase/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.10",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "miniprogram-api-typings": "^4.1.0",
    "miniprogram-automator": "^0.12.1",
    "miniprogram-ci": "^2.1.26",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^2.1.9",
    "weapp-vite": "^5.1.7",
    "wx-server-sdk": "^3.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}
